# --- Database ---------------------------------------------------------------
# In docker-compose this is set for you (points at the `db` service). For local
# `bun dev` against a local Postgres, set it here.
NUXT_DATABASE_URL=postgres://postcard:postcard@localhost:5432/postcard
POSTGRES_PASSWORD=postcard

# --- Redis ------------------------------------------------------------------
# Reserved for background jobs / caching integrations.
NUXT_REDIS_URL=redis://localhost:6379

# --- Parse Server + MongoDB -------------------------------------------------
# Parse runs alongside the app with its own MongoDB datastore.
# These defaults are fine for local/dev and can be left alone in Dokploy unless
# you explicitly want custom credentials.
MONGO_USER=emailhub
MONGO_PASSWORD=emailhub
MONGO_DB=parse
MONGO_BIND_ADDR=127.0.0.1
# MONGO_PORT=27017

PARSE_APP_ID=email-hub
PARSE_MASTER_KEY=
# PARSE_MOUNT_PATH=/parse
# PARSE_PUBLIC_URL=https://email-parse.eliasruiz.com/parse
# PARSE_ALLOW_CLIENT_CLASS_CREATION=false

# Files adapter: leave PARSE_SERVER_FILES_ADAPTER empty to fall back to GridFS.
# PARSE_SERVER_FILES_ADAPTER=@parse/s3-files-adapter
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=true
# S3_DIRECT_ACCESS=false
# S3_BASE_URL=
# S3_BUCKET_PREFIX=

# --- AI assistant (server-only; never exposed to users) ---------------------
NUXT_AI_BASE_URL=http://litellm:4000/v1
NUXT_AI_API_KEY=
NUXT_AI_MODEL=mini-v2

# Used by the LiteLLM gateway container (see litellm.config.yaml)
OPENAI_API_KEY=
LITELLM_MASTER_KEY=

# --- Stripe billing ---------------------------------------------------------
NUXT_STRIPE_SECRET_KEY=
NUXT_STRIPE_WEBHOOK_SECRET=
NUXT_STRIPE_PRICE_STARTER=
NUXT_STRIPE_PRICE_PRO=

# --- App --------------------------------------------------------------------
NUXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "1" to force secure session cookies (behind HTTPS / a TLS proxy)
NUXT_SESSION_COOKIE_SECURE=
