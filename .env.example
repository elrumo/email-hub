# Nuxt runtimeConfig is overridden via env vars prefixed with NUXT_
# (camelCase keys become SCREAMING_SNAKE_CASE).

# --- Uptime Kuma ---
NUXT_KUMA_URL=https://uptime.macosicons.com
# Kuma: Settings -> Security -> API Keys (uk2_... prefix)
NUXT_KUMA_API_KEY=uk2_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Bunny.net ---
# Account-level API key from https://dash.bunny.net/account/settings
NUXT_BUNNY_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- UI auth (optional - leave blank to expose without auth, e.g. behind Tailscale) ---
NUXT_UI_USERNAME=
NUXT_UI_PASSWORD=

# --- Notifications ---
NUXT_DISCORD_WEBHOOK_URL=
# Set "false" if Kuma already sends transition notifications and you don't want duplicates.
NUXT_NOTIFY_TRANSITIONS=true
NUXT_KUMA_ERROR_THRESHOLD=3

# --- Behavior ---
NUXT_POLL_INTERVAL_MS=30000
NUXT_COOLDOWN_MS=300000
NUXT_FAIL_THRESHOLD=2
NUXT_PROBE_TIMEOUT_MS=5000
NUXT_HISTORY_MAX=60
NUXT_BUNNY_CACHE_MS=60000

# --- Storage ---
NUXT_STATE_FILE=/data/state.json
NUXT_MAPPINGS_FILE=/data/mappings.json

# --- One-time seed for migration from the vanilla version ---
# If /data/mappings.json doesn't exist on first boot, this JSON is written to it
# and used as the initial mappings. After that, the UI is the source of truth
# and this var is ignored. Leave as "[]" if starting fresh.
NUXT_SEED_MAPPINGS=[]
