# ── Database ────────────────────────────────────────────────────────────────
# In docker-compose this is set for you (points at the `db` service). For local
# `bun dev` against a local Postgres, set it here.
NUXT_DATABASE_URL=postgres://postcard:postcard@localhost:5432/postcard
POSTGRES_PASSWORD=postcard

# ── AI assistant (server-only; never exposed to users) ───────────────────────
# We speak the OpenAI dialect to a LiteLLM gateway. The product only knows the
# model alias "mini-v2"; the real provider behind it is configured in
# litellm.config.yaml and stays hidden from the UI.
NUXT_AI_BASE_URL=http://litellm:4000/v1
NUXT_AI_API_KEY=sk-postcard-local
NUXT_AI_MODEL=mini-v2

# Used by the LiteLLM gateway container (see litellm.config.yaml)
OPENAI_API_KEY=sk-your-upstream-key
LITELLM_MASTER_KEY=sk-postcard-local

# ── Stripe billing ───────────────────────────────────────────────────────────
NUXT_STRIPE_SECRET_KEY=sk_test_xxx
NUXT_STRIPE_WEBHOOK_SECRET=whsec_xxx
NUXT_STRIPE_PRICE_STARTER=price_xxx
NUXT_STRIPE_PRICE_PRO=price_xxx

# ── App ──────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_APP_URL=http://localhost:3000
# Set to "1" to force secure session cookies (behind HTTPS / a TLS proxy)
NUXT_SESSION_COOKIE_SECURE=
