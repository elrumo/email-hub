# Nuxt runtimeConfig is overridden via env vars prefixed with NUXT_
# (camelCase keys become SCREAMING_SNAKE_CASE).

# --- Storage ---
# SQLite database file. In Docker this lives on the mounted /data volume.
NUXT_DB_FILE=/data/app.db
# Where the Drizzle migrations folder is at runtime (set automatically in Docker).
# For local `bun --bun run dev`, leave unset — it defaults to ./server/db/migrations.
# NUXT_MIGRATIONS_DIR=/app/migrations

# --- UI auth (optional — leave blank to expose without auth, e.g. behind Tailscale) ---
NUXT_UI_USERNAME=
NUXT_UI_PASSWORD=

# --- Scheduler ---
# How often the flow scheduler ticks (cron + poll triggers), in ms.
NUXT_SCHEDULER_INTERVAL_MS=30000

# --- Integrations ---
# Connections (Dokploy, Bunny, Uptime Kuma, Discord webhooks, …) are configured
# in the UI on the Connections page and stored in the database — NOT here.

# Optional: override the Bunny API base (rarely needed; useful for testing).
# NUXT_BUNNY_API_BASE=https://api.bunny.net

# --- Host/port (set by Docker; override for local) ---
# PORT=3000
