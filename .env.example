# Postcard — self-hosting configuration.
#
# Everything here has a working default in docker-compose.yml, so you can run
# `docker compose up --build` with NO .env at all. Copy this file to `.env`
# only to enable the AI assistant, harden secrets, or plug in SMTP.
#
#   cp .env.example .env
#
# The ONE thing worth setting for the full experience is NUXT_AI_API_KEY.

# --- AI assistant (optional but recommended) --------------------------------
# Postcard talks to any OpenAI-compatible endpoint. The simplest setup is an
# OpenAI key — leave NUXT_AI_BASE_URL empty to use OpenAI directly.
#   • OpenAI:  set NUXT_AI_API_KEY, leave NUXT_AI_BASE_URL empty
#   • Gateway: set NUXT_AI_BASE_URL to e.g. http://litellm:4000/v1 (+ its key)
#   • Ollama:  NUXT_AI_BASE_URL=http://host.docker.internal:11434/v1, model=llama3.1
# With none set, the app still runs — the AI features just show a clear
# "not configured" message.
NUXT_AI_API_KEY=
NUXT_AI_BASE_URL=
NUXT_AI_MODEL=gpt-4o-mini

# --- App --------------------------------------------------------------------
# The public URL your instance is served at (used in emails and share links).
NUXT_PUBLIC_APP_URL=http://localhost:3000
# Self-hosted mode: unlimited usage, no billing UI. Leave "true" for self-host.
NUXT_PUBLIC_SELF_HOSTED=true
# Set to "1" when serving over HTTPS behind a TLS proxy (secure cookies).
NUXT_SESSION_COOKIE_SECURE=
# Comma-separated emails that always have admin rights (the first account
# created is admin automatically, so this is optional).
ADMIN_EMAILS=

# --- Internal secrets -------------------------------------------------------
# These guard services that are only reachable on the private compose network,
# so the built-in defaults are fine for a local/home deploy. For an
# internet-exposed instance, generate your own (see `scripts/gen-secrets.sh`).
# PARSE_MASTER_KEY=
# MONGO_PASSWORD=
PARSE_APP_ID=email-hub

# --- Optional file storage --------------------------------------------------
# Leave PARSE_SERVER_FILES_ADAPTER empty to store uploads in Mongo (GridFS).
# Fill the S3 vars only if you want S3-compatible object storage instead.
PARSE_SERVER_FILES_ADAPTER=
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=true
# S3_DIRECT_ACCESS=false
# S3_BASE_URL=
# S3_BUCKET_PREFIX=

# --- Outgoing mail (optional) -----------------------------------------------
# Leave NUXT_MAIL_SMTP_HOST empty to log emails to the console instead of
# sending them (fine for trying things out).
NUXT_MAIL_SMTP_HOST=
NUXT_MAIL_SMTP_PORT=587
# Set to "1" for implicit TLS (port 465)
NUXT_MAIL_SMTP_SECURE=
NUXT_MAIL_SMTP_USER=
NUXT_MAIL_SMTP_PASS=
NUXT_MAIL_FROM="Postcard <no-reply@example.com>"

# --- Stripe billing (SaaS only; leave empty when self-hosting) --------------
# Ignored while NUXT_PUBLIC_SELF_HOSTED=true.
NUXT_STRIPE_SECRET_KEY=
NUXT_STRIPE_WEBHOOK_SECRET=
NUXT_STRIPE_PRICE_STARTER=
NUXT_STRIPE_PRICE_PRO=

# --- Use a prebuilt image instead of building locally (optional) ------------
# POSTCARD_IMAGE=ghcr.io/elrumo/email-hub:latest
